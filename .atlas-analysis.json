  "keyFeatures": [
    "OWASP project discovery and advanced search via Algolia",
    "Contribution opportunity finder aligned with contributor interests",
    "OWASP Chapters proximity map for local community engagement",
    "AI-generated project insights and actionable issue summaries",
    "NestBot Slack integration for commands, events, and messaging",
    "Google Summer of Code (GSoC) mentorship program support",
    "Dual API: REST (v0 via Django Ninja) and GraphQL (via Strawberry)",
    "GitHub integration for real-time project and issue data synchronization"
